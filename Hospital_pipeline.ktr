  <step>
    <name>Modified JavaScript value</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
// Clean phone number
var clean_phone;
if (phone == null) {
  clean_phone = null;
} else {
  clean_phone = String(phone).replace(/\(/g, '').replace(/\)/g, '').replace(/-/g, '').replace(/ /g, '');
}

// Age Category
var age_category;
if (age == null) {
  age_category = 'Unknown';
} else if (age &lt;= 12) {
  age_category = 'Child';
} else if (age &lt;= 17) {
  age_category = 'Teenager';
} else if (age &lt;= 35) {
  age_category = 'Young Adult';
} else if (age &lt;= 60) {
  age_category = 'Adult';
} else {
  age_category = 'Senior';
}

// Actual Amount Paid
var actual_amount_paid;
if (bill_amount == null || insurance_covered == null) {
  actual_amount_paid = bill_amount;
} else {
  actual_amount_paid = bill_amount - insurance_covered;
}

// Length of Stay
var length_of_stay;
var d1 = admission_date.getTime();
var d2 = discharge_date.getTime();
length_of_stay = Math.round((d2 - d1) / (1000 * 60 * 60 * 24));

// Insurance Coverage Percentage
var insurance_coverage_pct;
if (bill_amount == null || insurance_covered == null || bill_amount == 0) {
  insurance_coverage_pct = 0;
} else {
  insurance_coverage_pct = Math.round((insurance_covered / bill_amount) * 100);
}

// Admission Year
var admission_year;
var dateStr = String(admission_date);
admission_year = parseInt(dateStr.substring(0, 4));</jsScript_script>
      </jsScript>
    </jsScripts>
